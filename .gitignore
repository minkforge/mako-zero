# Runtime data — never commit
# (top-level only — `seed/notes/` is intentionally tracked)
/data/
/state/
/notes/
/workdir/
/archive/
/logs/
/pending/

# Populated config (only *.example.yaml is tracked)
/config.yaml

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Codex CLI session marker (created in cwd when meta runs)
.codex

# Build artefacts
*.log

# Working spec drafts and handover notes (uncommitted, local-only)
DASHBOARD-SPEC.md
OVERNIGHT-*.md
